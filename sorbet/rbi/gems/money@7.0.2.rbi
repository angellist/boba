  def ca_dollar(cents); end

  # pkg:gem/money#lib/money/money/constructors.rb:34
  def cad(cents); end

  # Create a new money object with value 0.
  #
  # @param [Currency, String, Symbol] currency The currency to use.
  #
  # @return [Money]
  #
  # @example
  #   Money.empty #=> #<Money @fractional=0>
  #
  # pkg:gem/money#lib/money/money/constructors.rb:14
  def empty(currency = T.unsafe(nil)); end

  # pkg:gem/money#lib/money/money/constructors.rb:67
  def eur(cents); end

  # Creates a new Money object of the given value, using the Euro currency.
  #
  # @param [Integer] cents The cents value.
  #
  # @return [Money]
  #
  # @example
  #   n = Money.euro(100)
  #   n.cents    #=> 100
  #   n.currency #=> #<Money::Currency id: eur>
  #
  # pkg:gem/money#lib/money/money/constructors.rb:64
  def euro(cents); end

  # pkg:gem/money#lib/money/money/constructors.rb:83
  def gbp(pence); end

  # Creates a new Money object of the given value, in British pounds.
  #
  # @param [Integer] pence The pence value.
  #
  # @return [Money]
  #
  # @example
  #   n = Money.pound_sterling(100)
  #   n.fractional    #=> 100
  #   n.currency #=> #<Money::Currency id: gbp>
  #
  # pkg:gem/money#lib/money/money/constructors.rb:80
  def pound_sterling(pence); end

  # Creates a new Money object of the given value, using the American dollar
  # currency.
  #
  # @param [Integer] cents The cents value.
  #
  # @return [Money]
  #
  # @example
  #   n = Money.us_dollar(100)
  #   n.cents    #=> 100
  #   n.currency #=> #<Money::Currency id: usd>
  #
  # pkg:gem/money#lib/money/money/constructors.rb:48
  def us_dollar(cents); end

  # pkg:gem/money#lib/money/money/constructors.rb:51
  def usd(cents); end

  # pkg:gem/money#lib/money/money/constructors.rb:17
  def zero(currency = T.unsafe(nil)); end
end

