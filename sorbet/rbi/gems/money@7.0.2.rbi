  #   bank.set_rate("CAD", "USD", 0.803115)
  #
  # pkg:gem/money#lib/money/bank/variable_exchange.rb:179
  def set_rate(from, to, rate, opts = T.unsafe(nil)); end

  # pkg:gem/money#lib/money/bank/variable_exchange.rb:66
  def store; end
end

